{
  "manifest_version": 3,
  "name": "AI Action Tracker",
  "version": "0.0.1",
  "description": "음성을 실시간으로 캡처하여 Action Item을 자동 추출하는 크롬 익스텐션",
  "permissions": ["sidePanel", "activeTab", "storage"],
  "side_panel": {
    "default_path": "sidepanel.html"
  },
  "action": {
    "default_popup": "popup.html"
  }
}
